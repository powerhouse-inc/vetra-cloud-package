{
  "name": "@powerhousedao/vetra-cloud-package",
  "version": "0.0.0-dev.1",
  "license": "AGPL-3.0-only",
  "type": "module",
  "files": [
    "/dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./document-models": {
      "types": "./dist/document-models/index.d.ts",
      "default": "./dist/document-models/index.js"
    },
    "./editors": {
      "types": "./dist/editors/index.d.ts",
      "default": "./dist/editors/index.js"
    },
    "./subgraphs": {
      "types": "./dist/subgraphs/index.d.ts",
      "default": "./dist/subgraphs/index.js"
    },
    "./processors": {
      "types": "./dist/processors/index.d.ts",
      "default": "./dist/processors/index.js"
    },
    "./processors/connect": {
      "types": "./dist/processors/connect.d.ts",
      "default": "./dist/processors/connect.js"
    },
    "./processors/switchboard": {
      "types": "./dist/processors/switchboard.d.ts",
      "default": "./dist/processors/switchboard.js"
    },
    "./manifest": {
      "default": "./dist/powerhouse.manifest.json"
    },
    "./style.css": "./dist/style.css",
    "./document-models/*": {
      "types": "./dist/document-models/*/index.d.ts",
      "default": "./dist/document-models/*/index.js"
    },
    "./editors/*": {
      "types": "./dist/editors/*/index.d.ts",
      "default": "./dist/editors/*/index.js"
    }
  },
  "scripts": {
    "lint": "eslint --config eslint.config.js --cache --cache-strategy content",
    "build:tsc": "tsc",
    "build:tsc:watch": "tsc --watch",
    "build:css": "npx @tailwindcss/cli -i ./style.css -o ./dist/style.css",
    "build:css:watch": "npx @tailwindcss/cli -i ./style.css -o ./dist/style.css --watch",
    "build": "npm run tsc && npm run tailwind",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "generate": "ph-cli generate",
    "connect": "ph-cli connect",
    "reactor": "ph-cli reactor",
    "service": "ph-cli service",
    "service-startup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-startup.sh",
    "service-unstartup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-unstartup.sh",
    "lint:fix": "npm run lint -- --fix",
    "tsc": "tsc",
    "tsc:watch": "tsc --watch",
    "tailwind": "pnpm exec tailwindcss -i ./style.css -o ./dist/style.css",
    "check-circular-imports": "npx dpdm -T ./index.ts",
    "vetra": "ph-cli vetra",
    "migrate": "ph-cli migrate"
  },
  "dependencies": {
    "@powerhousedao/builder-tools": "6.0.0-dev.100",
    "@powerhousedao/common": "6.0.0-dev.100",
    "@powerhousedao/connect": "6.0.0-dev.100",
    "@powerhousedao/design-system": "6.0.0-dev.100",
    "@powerhousedao/document-engineering": "^1.34.0",
    "cmd-ts": "^0.15.0",
    "document-model": "6.0.0-dev.100",
    "graphql": "^16.10.0",
    "graphql-tag": "^2.12.6",
    "kysely": "^0.28.11",
    "uuid": "^11.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@eslint/js": "^9.22.0",
    "@powerhousedao/analytics-engine-core": "^0.5.0",
    "@powerhousedao/codegen": "6.0.0-dev.100",
    "@powerhousedao/ph-cli": "6.0.0-dev.100",
    "@powerhousedao/reactor-api": "6.0.0-dev.100",
    "@powerhousedao/reactor-browser": "6.0.0-dev.100",
    "@powerhousedao/reactor-local": "6.0.0-dev.100",
    "@powerhousedao/scalars": "staging",
    "@powerhousedao/switchboard": "6.0.0-dev.100",
    "@powerhousedao/vetra": "6.0.0-dev.100",
    "@tailwindcss/cli": "^4.0.15",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.13.11",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "document-drive": "6.0.0-dev.100",
    "eslint": "^9.22.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "package-manager-detector": "^0.2.8",
    "pm2": "^5.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.2.3",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^3.0.9"
  },
  "pnpm": {
    "overrides": {
      "@openfeature/core": "^1.9.2"
    }
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
