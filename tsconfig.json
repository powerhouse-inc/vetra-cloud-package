{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "module": "nodenext",
    "target": "esnext",
    "types": [
      "node",
      "vitest/globals"
    ],
    "lib": [
      "ESNext",
      "dom",
      "dom.iterable"
    ],
    "sourceMap": false,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "paths": {
      "@powerhousedao/vetra-cloud-package/document-models": [
        "./document-models/index.ts"
      ],
      "@powerhousedao/vetra-cloud-package/document-models/*": [
        "./document-models/*/index.ts"
      ],
      "@powerhousedao/vetra-cloud-package/editors": [
        "./editors/index.ts"
      ],
      "@powerhousedao/vetra-cloud-package/editors/*": [
        "./editors/*/index.ts"
      ],
      "document-models/vetra-cloud-environment/v1": [
        "./document-models/vetra-cloud-environment/v1/index.ts"
      ],
      "document-models/vetra-cloud-environment/upgrades": [
        "./document-models/vetra-cloud-environment/upgrades/index.ts"
      ]
    }
  },
  "include": [
    "**/*",
    "./powerhouse.manifest.json"
  ],
  "exclude": [
    "dist",
    "node_modules",
    ".ph",
    "vitest.config.ts",
    "**/*.test.ts",
    "**/e2e.test.ts",
    "**/gen/**/object.ts",
    "**/gen/object.ts"
  ]
}
