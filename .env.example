# GitOps Processor Configuration
GITOPS_REPO_PATH=/path/to/powerhouse-k8s-cluster
GITOPS_GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITOPS_REMOTE=origin
GITOPS_BRANCH=main

# GitHub App (vetra-github-auth subgraph) — backend-only secrets.
# Source from a k8s secret in deployment; never commit real values or place the
# private key in a document model or the sync layer.
GITHUB_APP_ID=123456
# Public client_id of the GitHub App. Used for the browser-proxied device flow;
# device flow needs no client secret.
GITHUB_APP_CLIENT_ID=Iv1.0123456789abcdef
# PKCS#1 PEM as issued by GitHub. Newlines may be escaped as \n in a single line.
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
